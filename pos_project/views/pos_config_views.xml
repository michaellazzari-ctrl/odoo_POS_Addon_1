<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="view_pos_config_project" model="ir.ui.view">
        <field name="name">pos.config.project</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//setting[last()]" position="after">

                <setting string="Projects">

                    <field name="project_required"/>

                </setting>

            </xpath>

        </field>
    </record>

</odoo>
