<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- POS Config Form View -->
        <record id="pos_config_form_view" model="ir.ui.view">
            <field name="name">pos.config.form</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_form_view"/>
            <field name="arch" type="xml">
                <field name="module_account" position="after">
                    <field name="custom_config"/>
                    <field name="config_parameter"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
