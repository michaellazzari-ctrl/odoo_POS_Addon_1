<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Project Form View -->
        <record id="project_form_view" model="ir.ui.view">
            <field name="name">project.project.form</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.view_project_form"/>
            <field name="arch" type="xml">
                <div name="button_box" position="inside">
                    <button name="action_view_pos_orders" class="oe_stat_button" type="object" icon="fa-shopping-cart">
                        <field name="pos_order_count" widget="statinfo" string="POS Orders"/>
                    </button>
                </div>
            </field>
        </record>
    </data>
</odoo>
